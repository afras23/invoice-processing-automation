# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── AI model (optional, defaults shown) ─────────────────────────────────────
AI_MODEL=claude-3-5-sonnet-20241022

# ── Approval threshold: invoices above this amount require manual approval ───
APPROVAL_THRESHOLD=500.0

# ── Slack (optional) — omit to disable notifications ────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Google Sheets (optional) — omit service_account.json to disable ──────────
SERVICE_ACCOUNT_FILE=service_account.json
SHEETS_DOCUMENT_NAME=Invoices

# ── Database (used by docker-compose) ───────────────────────────────────────
DB_NAME=invoices
DB_USER=appuser
DB_PASSWORD=apppass
DB_PORT=5432

# ── Server ───────────────────────────────────────────────────────────────────
API_PORT=8000
APP_ENV=development
