# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── AI model (optional, defaults shown) ─────────────────────────────────────
AI_MODEL=claude-3-5-sonnet-20241022

# ── AI cost tracking (USD per token, defaults match claude-3-5-sonnet pricing)
AI_COST_PER_INPUT_TOKEN_USD=0.000003
AI_COST_PER_OUTPUT_TOKEN_USD=0.000015

# ── Daily AI cost limit — requests are rejected once this is reached ─────────
MAX_DAILY_COST_USD=10.0

# ── AI retry / circuit breaker ───────────────────────────────────────────────
AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY_SECONDS=1.0
AI_CIRCUIT_BREAKER_THRESHOLD=5
AI_CIRCUIT_BREAKER_RESET_SECONDS=60.0

# ── Approval threshold: invoices above this amount require manual approval ───
APPROVAL_THRESHOLD=500.0

# ── Slack (optional) — omit to disable notifications ────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Google Sheets (optional) — omit service_account.json to disable ──────────
SERVICE_ACCOUNT_FILE=service_account.json
SHEETS_DOCUMENT_NAME=Invoices

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://appuser:apppass@localhost:5432/invoices
DB_NAME=invoices
DB_USER=appuser
DB_PASSWORD=apppass
DB_PORT=5432

# ── Server ───────────────────────────────────────────────────────────────────
API_PORT=8000
APP_ENV=development
